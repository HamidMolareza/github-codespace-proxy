{
  "ConnectionStrings": {
    "Default": "Data Source=data/gh-proxy.db"
  },
  "ProxyRuntime": {
    "IdleShutdownMinutes": 30,
    "ActivityProbeSeconds": 60,
    "RemoteDirectory": "~/.gh-proxy",
    "KnownHostsPath": "data/known_hosts",
    "TunnelCommandName": "autossh"
  },
  "Observability": {
    "LogDirectory": "data/logs",
    "RetentionDays": 14,
    "MaxOutputChars": 4000,
    "EnableJsonlFile": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
